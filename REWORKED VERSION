-- MOBILE VERTICAL BUTTONS
local function createVerticalBtn(name, pos, callback)
    local b = Instance.new("TextButton", sgui)
    b.Size, b.Position = UDim2.new(0, 65, 0, 65), pos
    b.Text, b.BackgroundColor3 = name, Color3.fromRGB(30, 30, 30)
    b.TextColor3, b.Font, b.TextSize = Color3.new(1, 0, 0), Enum.Font.GothamBold, 25
    b.Visible = false
    Instance.new("UICorner", b).CornerRadius = UDim.new(0, 12)
    local s = Instance.new("UIStroke", b)
    s.Color, s.Thickness = Color3.fromRGB(255, 0, 0), 2
    b.MouseButton1Down:Connect(function() callback(true) end)
    b.MouseButton1Up:Connect(function() callback(false) end)
    return b
end
local upBtn = createVerticalBtn("▲", UDim2.new(1, -80, 0.5, -75), function(v) upVal = v and 1 or 0 end)
local downBtn = createVerticalBtn("▼", UDim2.new(1, -80, 0.5, 5), function(v) downVal = v and 1 or 0 end)

