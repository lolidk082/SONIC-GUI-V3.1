-- SONICGUI V2. FINAL RED NEON WIDE EDITION
local player = game.Players.LocalPlayer
local UIS = game:GetService("UserInputService")
local runService = game:GetService("RunService")
local mouse = player:GetMouse()

-- 1. STATE VARIABLES
local flying, godMode, infJumpEnabled, flinging, catchingFire, clickTPEnabled = false, false, false, false, false, false
local upVal, downVal = 0, 0 

local function getChar()
    local char = player.Character or player.CharacterAdded:Wait()
    local hum = char:FindFirstChildOfClass("Humanoid")
    local root = char:FindFirstChild("HumanoidRootPart")
    return char, hum, root
end

local function getNearestPlayer()
    local closestPlayer, shortestDistance = nil, math.huge
    local _, _, myRoot = getChar()
    if not myRoot then return nil end
    for _, p in pairs(game.Players:GetPlayers()) do
        if p ~= player and p.Character and p.Character:FindFirstChild("HumanoidRootPart") then
            local dist = (myRoot.Position - p.Character.HumanoidRootPart.Position).Magnitude
            if dist < shortestDistance then shortestDistance, closestPlayer = dist, p end
        end
    end
    return closestPlayer
end

