-- ORIGINAL BUTTON FUNCTION
local function createBtn(name, color, callback)
    local btn = Instance.new("TextButton", container)
    btn.BackgroundColor3, btn.Text, btn.TextColor3 = Color3.fromRGB(40, 40, 40), name, Color3.new(1, 1, 1)
    btn.Font, btn.TextSize = Enum.Font.GothamSemibold, 11
    Instance.new("UICorner", btn).CornerRadius = UDim.new(0, 6)
    local bStroke = Instance.new("UIStroke", btn)
    bStroke.Color = color
    btn.MouseButton1Click:Connect(function() callback(btn) end)
end

-- NEW SECTION FUNCTION (RETAINING ORIGINAL STYLE)
local function createSection(text)
    local sectionLab = Instance.new("TextLabel", container)
    sectionLab.Size = UDim2.new(1, 0, 0, 30)
    sectionLab.BackgroundTransparency = 1
    sectionLab.Text = "--- " .. text .. " ---"
    sectionLab.TextColor3 = Color3.new(1, 0, 0)
    sectionLab.Font = Enum.Font.GothamBold
    sectionLab.TextSize = 14
end

-- 3. APPLY ALL FEATURES IN SECTIONS
createSection("MOVEMENT")
createBtn("Fly (Mobile)", Color3.new(1, 1, 1), function() 
    flying = not flying 
    upBtn.Visible, downBtn.Visible = flying, flying
    local _, hum, r = getChar() 
    if flying and r then 
        local bv = Instance.new("BodyVelocity", r)
        bv.MaxForce = Vector3.new(1,1,1)*math.huge
        task.spawn(function() 
            while flying and r.Parent do 
                bv.Velocity = (hum.MoveDirection * 70) + (Vector3.new(0, (upVal - downVal), 0) * 70)
                hum.PlatformStand = true
                task.wait() 
            end 
            if hum then hum.PlatformStand = false end
            bv:Destroy() 
        end)
    end
end)
createBtn("Inf Jump (On)", Color3.fromRGB(255, 170, 0), function() infJumpEnabled = not infJumpEnabled end)
createBtn("Click TP (Off)", Color3.fromRGB(0, 170, 255), function(self)
    clickTPEnabled = not clickTPEnabled
    self.Text = clickTPEnabled and "Click TP (On)" or "Click TP (Off)"
end)
createBtn("Reset Speed", Color3.new(0.5, 0.5, 0.5), function() local _, h = getChar() if h then h.WalkSpeed = 16 end end)

createSection("COMBAT")
createBtn("Fling (Toggle)", Color3.fromRGB(255, 0, 255), function()
    flinging = not flinging
    local _, _, root = getChar()
    if flinging and root then
        local av = Instance.new("AngularVelocity", root)
        av.MaxTorque, av.AngularVelocity = math.huge, Vector3.new(0, 999999, 0)
        av.Attachment0 = root:FindFirstChild("RootRigAttachment") or Instance.new("Attachment", root)
        task.spawn(function()
            while flinging and root.Parent do
                local t = getNearestPlayer()
                if t and t.Character and t.Character:FindFirstChild("HumanoidRootPart") then root.CFrame = t.Character.HumanoidRootPart.CFrame end
                runService.Heartbeat:Wait()
            end
            av:Destroy()
        end)
    end
end)
createBtn("Sonic Pistol", Color3.fromRGB(0, 255, 150), function()
    local gun = Instance.new("Tool", player.Backpack)
    gun.Name = "Sonic Pistol"; local handle = Instance.new("Part", gun)
    handle.Name = "Handle"; handle.Size = Vector3.new(0.5, 0.5, 1.5); handle.Color = Color3.fromRGB(255, 0, 0)
    gun.Activated:Connect(function()
        local target = mouse.Target
        if target and target.Parent:FindFirstChild("Humanoid") then
            local re = game:GetService("ReplicatedStorage"):FindFirstChild("DamageEvent")
            if re then re:FireServer(target.Parent.Humanoid, 30) end
        end
    end)
end)

createSection("MISC & RISKY")
createBtn("Catching Fire", Color3.fromRGB(255, 85, 0), function()
    catchingFire = not catchingFire
    task.spawn(function()
        while catchingFire do
            for _, p in pairs(game.Players:GetPlayers()) do
                if p ~= player and p.Character then
                    local r = p.Character:FindFirstChild("HumanoidRootPart")
                    if r and not r:FindFirstChild("SonicFire") then Instance.new("Fire", r).Name = "SonicFire" end
                end
            end
            task.wait(1)
        end
    end)
end)
