        for i=1,10 do for _,p in ipairs(c:GetDescendants()) do if p:IsA("BasePart") then p.Color = Color3.new(1,0,0) end end task.wait(.15) end
        h.Health = 0
    end)
end)

-- Loops
task.spawn(function() while task.wait(0.1) do if godMode then local _, h = getChar() if h then h.Health = h.MaxHealth end end end end)
